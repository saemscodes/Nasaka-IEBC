{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "recall254.vercel.app"
        }
      ],
      "destination": "https://nasakaiebc.civiceducationkenya.com/$1",
      "permanent": true
    },
    {
      "source": "/docs",
      "destination": "https://docs.nasakaiebc.civiceducationkenya.com/",
      "permanent": true
    },
    {
      "source": "/docs/(.*)",
      "destination": "https://docs.nasakaiebc.civiceducationkenya.com/$1",
      "permanent": true
    },
    {
      "source": "/IEBC.office",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-office",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-office/map",
      "destination": "/map",
      "permanent": true
    },
    {
      "source": "/iebc-office/privacy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/iebc-office/terms",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/nasaka-iebc/privacy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/nasaka-iebc/terms",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/iebc-office/:county/:constituency",
      "destination": "/:county/:constituency",
      "permanent": true
    },
    {
      "source": "/iebc-office/:county",
      "destination": "/:county",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/locate",
      "destination": "/api/v1/main?route=locate"
    },
    {
      "source": "/api/v1/boundary",
      "destination": "/api/v1/main?route=boundary"
    },
    {
      "source": "/api/v1/coordinates",
      "destination": "/api/v1/main?route=coordinates"
    },
    {
      "source": "/api/v1/counties",
      "destination": "/api/v1/main?route=counties"
    },
    {
      "source": "/api/v1/health",
      "destination": "/api/v1/main?route=health"
    },
    {
      "source": "/api/v1/offices",
      "destination": "/api/v1/main?route=offices"
    },
    {
      "source": "/api/v1/offices/:id",
      "destination": "/api/v1/main?route=offices&id=:id"
    },
    {
      "source": "/api/v1/stats",
      "destination": "/api/v1/main?route=stats"
    },
    {
      "source": "/api/v1/status",
      "destination": "/api/v1/main?route=status"
    },
    {
      "source": "/api/v1/billing/paystack",
      "destination": "/api/v1/billing/paystack"
    },
    {
      "source": "/api/v1/enterprise/enquire",
      "destination": "/api/services?service=enquire"
    },
    {
      "source": "/api/v1/licenses/download",
      "destination": "/api/services?service=download"
    },
    {
      "source": "/api/v1/auth/ceka/callback",
      "destination": "/api/services?service=callback"
    },
    {
      "source": "/api/ai-proxy",
      "destination": "/api/v1/main?route=ai-proxy"
    },
    {
      "source": "/api/create-signature-session",
      "destination": "/api/services?service=signature-session"
    },
    {
      "source": "/api/petition-stats",
      "destination": "/api/services?service=petition-stats"
    },
    {
      "source": "/api/usage",
      "destination": "/api/services?service=usage"
    },
    {
      "source": "/api/trigger-workflow",
      "destination": "/api/services?service=workflow"
    },
    {
      "source": "/api/verify-voter",
      "destination": "/api/services?service=verify-voter"
    },
    {
      "source": "/api/404-message",
      "destination": "/api/services?service=404"
    },
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/v1/main?route=$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/services?service=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://www.civiceducationkenya.com https://civiceducationkenya.com https://civicedkenya.vercel.app"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self)"
        }
      ]
    },
    {
      "source": "/api/v1/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, X-API-Key, Authorization"
        },
        {
          "key": "Timing-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/api/ai-proxy",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "Access-Control-Max-Age",
          "value": "86400"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": []
}