{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "recall254.vercel.app"
        }
      ],
      "destination": "https://nasakaiebc.civiceducationkenya.com/$1",
      "permanent": true
    },
    {
      "source": "/IEBC.office",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-office",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-office/map",
      "destination": "/map",
      "permanent": true
    },
    {
      "source": "/iebc-office/privacy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/iebc-office/terms",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/nasaka-iebc/privacy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/nasaka-iebc/terms",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/iebc-office/:county/:constituency",
      "destination": "/:county/:constituency",
      "permanent": true
    },
    {
      "source": "/iebc-office/:county",
      "destination": "/:county",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/billing/initialize",
      "destination": "/api/v1/billing/paystack/initialize"
    },
    {
      "source": "/api/v1/billing/verify",
      "destination": "/api/v1/billing/paystack/verify"
    },
    {
      "source": "/api/v1/billing/webhook",
      "destination": "/api/v1/billing/paystack/webhook"
    },
    {
      "source": "/api/v1/auth/ceka/callback",
      "destination": "/api/v1/auth/ceka/callback"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self)"
        }
      ]
    },
    {
      "source": "/api/v1/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, X-API-Key, Authorization"
        },
        {
          "key": "Timing-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/v1/billing/cron/renewal-check",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v1/cron/regenerate-datasets",
      "schedule": "0 2 * * *"
    }
  ]
}