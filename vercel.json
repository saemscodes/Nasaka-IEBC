{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "recall254.vercel.app"
        }
      ],
      "destination": "https://nasakaiebc.civiceducationkenya.com/$1",
      "permanent": true
    },
    {
      "source": "/IEBC.office",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-%E2%80%A6",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebce-office",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebcoffice",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-app",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-offfice",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-offices",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc/office",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc_office",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/%20iebc-office",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/IEBC-OFFICE",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-office",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/iebc-office/map",
      "destination": "/map",
      "permanent": true
    },
    {
      "source": "/iebc-office/privacy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/iebc-office/terms",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/nasaka-iebc/privacy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/nasaka-iebc/terms",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/iebc-office/:county/:constituency",
      "destination": "/:county/:constituency",
      "permanent": true
    },
    {
      "source": "/iebc-office/:county",
      "destination": "/:county",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/billing/initialize",
      "destination": "/api/v1/billing/paystack/initialize"
    },
    {
      "source": "/api/v1/billing/verify",
      "destination": "/api/v1/billing/paystack/verify"
    },
    {
      "source": "/api/v1/billing/webhook",
      "destination": "/api/v1/billing/paystack/webhook"
    },
    {
      "source": "/api/v1/enterprise/enquire",
      "destination": "/api/v1/enterprise/enquire"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/v1/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, X-API-Key, x-paystack-signature"
        }
      ]
    },
    {
      "source": "/api/v1/billing/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, X-API-Key, x-paystack-signature"
        }
      ]
    },
    {
      "source": "/api/v1/enterprise/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/v1/billing/cron/renewal-check",
      "schedule": "0 3 * * *"
    }
  ]
}